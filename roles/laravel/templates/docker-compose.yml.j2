---
services:
  app:
    image: {{ laravel_site.laravel_image }}
    restart: unless-stopped
    env_file: .env
    volumes:
      - ./storage:/var/www/html/storage
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ laravel_site.site_name }}.rule=Host(`{{ laravel_site.site_domain }}`)"
      - "traefik.http.routers.{{ laravel_site.site_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ laravel_site.site_name }}.tls.certresolver=le"
    networks:
      - proxy

{% if laravel_site.laravel_queue_enabled %}
  queue:
    image: {{ laravel_site.laravel_image }}
    restart: unless-stopped
    env_file: .env
    command: php artisan queue:work --sleep=3 --tries=3
    networks:
      - proxy
{% endif %}

networks:
  proxy:
    name: {{ docker_proxy_network }}
    external: true
