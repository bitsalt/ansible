APP_NAME=Laravel
APP_ENV={{ laravel_site.laravel_app_env }}
APP_KEY={{ laravel_site.laravel_app_key }}
APP_DEBUG={{ laravel_site.laravel_app_debug }}
APP_URL=https://{{ laravel_site.site_domain }}

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST={{ laravel_site.laravel_db_host }}
DB_PORT={{ laravel_site.laravel_db_port }}
DB_DATABASE={{ laravel_site.laravel_db_name }}
DB_USERNAME={{ laravel_site.laravel_db_user }}
DB_PASSWORD={{ laravel_site.laravel_db_password }}

CACHE_DRIVER=file
QUEUE_CONNECTION={% if laravel_site.laravel_queue_enabled %}database{% else %}sync{% endif %}

SESSION_DRIVER=file
SESSION_LIFETIME=120
