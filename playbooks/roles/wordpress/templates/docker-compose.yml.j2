---
services:
  wordpress:
    build: .
    image: {{ item.site_name }}-wordpress
    restart: unless-stopped
    env_file: .env
    volumes:
      - wordpress_data:/var/www/html
      - ./wp-content:/var/www/html/wp-content
    networks:
      - internal

  nginx:
    image: nginx:alpine
    restart: unless-stopped
    volumes:
      - wordpress_data:/var/www/html:ro
      - ./wp-content:/var/www/html/wp-content:ro
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
    labels:
      - "traefik.enable=true"
      # Explicit service definition so both routers can reference it by site name
      - "traefik.http.services.{{ item.site_name }}.loadbalancer.server.port=80"
      # WordPress-specific middleware: block xmlrpc.php abuse
      - "traefik.http.middlewares.block-xmlrpc.replacepathregex.regex=^/xmlrpc.php"
      - "traefik.http.middlewares.block-xmlrpc.replacepathregex.replacement=/xmlrpc-blocked"
      # WordPress-specific middleware: rate-limit login (5 req/min avg, burst 10)
      # Applied to the full router; tune or scope to /wp-login.php via a path router if needed
      - "traefik.http.middlewares.ratelimit-login.ratelimit.average=5"
      - "traefik.http.middlewares.ratelimit-login.ratelimit.burst=10"
      - "traefik.http.middlewares.ratelimit-login.ratelimit.period=1m"
      # Apex domain router
      - "traefik.http.routers.{{ item.site_name }}.rule=Host(`{{ item.site_domain }}`)"
      - "traefik.http.routers.{{ item.site_name }}.entrypoints=websecure"
      - "traefik.http.routers.{{ item.site_name }}.tls.certresolver=le"
      - "traefik.http.routers.{{ item.site_name }}.middlewares=block-xmlrpc"
      # wp-login.php router — scoped rate limit; longer rule wins priority over apex router
      - "traefik.http.routers.{{ item.site_name }}-login.rule=Host(`{{ item.site_domain }}`) && Path(`/wp-login.php`)"
      - "traefik.http.routers.{{ item.site_name }}-login.entrypoints=websecure"
      - "traefik.http.routers.{{ item.site_name }}-login.tls.certresolver=le"
      - "traefik.http.routers.{{ item.site_name }}-login.middlewares=ratelimit-login"
      - "traefik.http.routers.{{ item.site_name }}-login.service={{ item.site_name }}"
      # www → apex redirect (permanent 301)
      - "traefik.http.routers.{{ item.site_name }}-www.rule=Host(`www.{{ item.site_domain }}`)"
      - "traefik.http.routers.{{ item.site_name }}-www.entrypoints=websecure"
      - "traefik.http.routers.{{ item.site_name }}-www.tls.certresolver=le"
      - "traefik.http.routers.{{ item.site_name }}-www.middlewares={{ item.site_name }}-www-redirect"
      - "traefik.http.routers.{{ item.site_name }}-www.service={{ item.site_name }}"
      - "traefik.http.middlewares.{{ item.site_name }}-www-redirect.redirectregex.regex=^https://www\\.(.+)"
      - "traefik.http.middlewares.{{ item.site_name }}-www-redirect.redirectregex.replacement=https://$$1"
      - "traefik.http.middlewares.{{ item.site_name }}-www-redirect.redirectregex.permanent=true"
    networks:
      - proxy
      - internal
    depends_on:
      - wordpress

volumes:
  wordpress_data:

networks:
  proxy:
    name: {{ docker_proxy_network }}
    external: true
  internal:
